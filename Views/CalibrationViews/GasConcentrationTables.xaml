<UserControl x:Class="CapnoAnalyzer.Views.CalibrationViews.GasConcentrationTables"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CapnoAnalyzer.Views.CalibrationViews"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid Margin="3">
        <Border Background="#F1F3FA" CornerRadius="10" Padding="3" BorderBrush="#D1D5DB" BorderThickness="1">
            <StackPanel>
                <!-- Bağlı cihazlar (COM port) - üstte -->
                <TabControl ItemsSource="{Binding DeviceTables}"
                            SelectedItem="{Binding ActiveDeviceTable, Mode=TwoWay}"
                            Margin="3"
                            Background="#F1F3FA">
                    <TabControl.Style>
                        <Style TargetType="TabControl">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DeviceTables.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Style>

                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DeviceName}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>

                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <local:GasConcentrationTablePanel />
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <Separator Margin="8,4"
                           Background="#CBD5E1"
                           Height="2">
                    <Separator.Style>
                        <Style TargetType="Separator">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DeviceTables.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Separator.Style>
                </Separator>

                <!-- Dış veri inceleme - her zaman altta -->
                <Border Margin="3"
                        Padding="8"
                        CornerRadius="8"
                        BorderBrush="#94A3B8"
                        BorderThickness="2"
                        Background="#EEF2FF">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <TextBlock Text="📁" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ManualImportTable.DeviceName}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#1E293B"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Cihaz bağlantısı olmadan dışarıdan import edilen kalibrasyon verilerini inceleyebilir, hesaplayabilir ve export edebilirsiniz."
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   Margin="0,0,0,8"/>
                        <local:GasConcentrationTablePanel DataContext="{Binding ManualImportTable}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
