<UserControl x:Class="CapnoAnalyzer.Views.DevicesViews.Devices.Devices"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CapnoAnalyzer.Views.DevicesViews.Devices"            
             xmlns:helpers="clr-namespace:CapnoAnalyzer.Helpers"              
             xmlns:devicesDC="clr-namespace:CapnoAnalyzer.Views.DevicesViews.DevicesControl"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Küçük başlık etiketi -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10"
          HorizontalAlignment="Center"
          MaxWidth="1100">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- (A) Port Seçim Alanı - üstte, iki kolonu kaplar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Bağlantı Ayarları"
                           Style="{StaticResource SectionTitle}"/>
                <devicesDC:PortsConnection DataContext="{Binding}"/>
            </StackPanel>
        </Border>

        <!-- (B) Port Listesi - sol alt -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Sistem Üzerindeki Portlar"
                           Style="{StaticResource SectionTitle}"/>
                <devicesDC:DevicesList DataContext="{Binding}"/>
            </StackPanel>
        </Border>

        <!-- (C) Bağlı Cihazlar - sağ alt -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <StackPanel>
                <TextBlock Text="Bağlı Cihazlar"
                           Style="{StaticResource SectionTitle}"/>
                <devicesDC:ConnectedDevices DataContext="{Binding}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
