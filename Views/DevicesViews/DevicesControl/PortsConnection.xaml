<UserControl x:Class="CapnoAnalyzer.Views.DevicesViews.DevicesControl.PortsConnection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CapnoAnalyzer.Views.DevicesViews.DevicesControl"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6B7280"/>
        </Style>

        <Style x:Key="TertiaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#10B981"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ID -->
        <StackPanel Grid.Column="0"
                    Margin="0,0,10,0">
            <TextBlock Text="ID"
                       Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding DeviceID}"
                     Width="150"
                     FontWeight="Bold"
                     Style="{StaticResource ModernTextBox}"/>
        </StackPanel>

        <!-- Veri Paketi Tipi -->
        <StackPanel Grid.Column="1"
                    Margin="0,0,10,0">
            <TextBlock Text="Veri Paketi Tipi"
                       Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding DataPacketType}"
                     Width="150"
                     FontWeight="Bold"
                     Style="{StaticResource ModernTextBox}"/>
        </StackPanel>

        <!-- Port -->
        <StackPanel Grid.Column="2"
                    Margin="0,0,10,0">
            <TextBlock Text="Port"
                       Style="{StaticResource FieldLabel}"/>
            <ComboBox Width="150"
                      ItemsSource="{Binding AvailablePorts}"
                      SelectedItem="{Binding SelectedPortName}"
                      Style="{StaticResource ModernComboBox}"/>
        </StackPanel>

        <!-- Baud Hızı -->
        <StackPanel Grid.Column="3"
                    Margin="0,0,10,0">
            <TextBlock Text="Baud Hızı"
                       Style="{StaticResource FieldLabel}"/>
            <ComboBox SelectedValue="{Binding SelectedBaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Content"
                      Width="150"
                      HorizontalAlignment="Left"
                      Style="{StaticResource ModernComboBox}">
                <ComboBoxItem Content="9600" />
                <ComboBoxItem Content="115200" />
                <ComboBoxItem Content="230400" />
                <ComboBoxItem Content="460800" />
                <ComboBoxItem Content="921600" />
            </ComboBox>
        </StackPanel>

        <!-- Butonlar -->
        <StackPanel Grid.Column="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button Content="Connect"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ConnectCommand}"/>
            <Button Content="Disconnect"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding DisconnectCommand}"/>
            <Button Content="Identify Device"
                    Style="{StaticResource TertiaryButton}"
                    Command="{Binding IdentifyDeviceCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
