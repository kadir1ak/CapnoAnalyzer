<Page x:Class="CapnoAnalyzer.Views.Pages.DeviceConnectionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CapnoAnalyzer.Views.Pages"   
      xmlns:views="clr-namespace:CapnoAnalyzer.Views.DevicesViews.Devices"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1100"
      Title="Cihaz Bağlantıları">

    <Grid Margin="6">
        <Border Background="#F8FAFC"
                CornerRadius="3"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12"
                                  ShadowDepth="1"
                                  Opacity="0.12"
                                  Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ══════════════════════════════════════════════════════ -->
                <!-- ── Başlık Bar ── -->
                <!-- ══════════════════════════════════════════════════════ -->
                <Border Grid.Row="0" CornerRadius="3,3,0,0" Padding="20,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#111827" Offset="0"/>
                            <GradientStop Color="#1F2937" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sol: Başlık ve açıklama -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,16,0">
                            <Border Width="36"
                                    Height="36"
                                    CornerRadius="16"
                                    Background="#BFDBFE"
                                    VerticalAlignment="Center">
                                <TextBlock Text="🔌"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10 0 0 0">
                                <TextBlock Text="Cihaz Bağlantıları ve Yönetim Paneli"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="Bağlı cihazları görüntüleyin, bağlantı durumlarını izleyin ve yönetim işlemlerini gerçekleştirin."
                                           FontSize="11"
                                           Foreground="#9CA3AF"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Sağ: İleride eklenecek aksiyon butonları için boş alan -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,4,0">
                            <!-- İşlevselliği bozmamak için şu an buton eklenmiyor -->
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════════ -->
                <!-- ── Ana İçerik: Devices UserControl ── -->
                <!-- ══════════════════════════════════════════════════════ -->
                <Border Grid.Row="1"
                        Background="#FFFFFF"
                        CornerRadius="0,0,3,3">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <!-- Devices UserControl'ü, DataContext => MainViewModel.DevicesVM -->
                        <views:Devices DataContext="{Binding DevicesVM}" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
